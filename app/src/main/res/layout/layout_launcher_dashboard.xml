<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- GIAO DIỆN LÁI XE (DASHBOARD) -->
    <LinearLayout
        android:id="@+id/layout_driving_dashboard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0A0F1A"
        android:orientation="vertical"
        android:weightSum="100">

        <!-- Top Section: Info, Speed, Gear (40%) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="40"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

<!--            <ImageView-->
<!--                android:id="@+id/iv_car_status"-->
<!--                android:layout_width="30dp"-->
<!--                android:layout_height="30dp"-->
<!--                android:src="@android:drawable/ic_menu_info_details"-->
<!--                android:alpha="0.6"-->
<!--                android:contentDescription="Status" />-->

            <TextView
                android:id="@+id/tv_launcher_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="70sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="km/h"
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                android:layout_marginTop="-10dp"/>

            <TextView
                android:id="@+id/tv_launcher_gear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:text="R N D"
                android:textColor="#444444"
                android:textSize="22sp"
                android:letterSpacing="0.8"/>
        </LinearLayout>

        <!-- Middle Section: SOC & Range (10%) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="10"
            android:background="#121826"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_launcher_soc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="87%"
                android:textColor="#00E5FF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <View android:layout_width="1dp" android:layout_height="20dp" android:background="#333333" android:layout_marginHorizontal="20dp"/>

            <TextView
                android:id="@+id/tv_launcher_range"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="391 km"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />
        </LinearLayout>

        <!-- Bottom Section: Driving Modes (50%) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="50"
            android:orientation="vertical"
            android:padding="15dp"
            android:gravity="center_vertical">

            <!-- Chế độ lái -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chế độ lái"
                android:textColor="#AAAAAA"
                android:textSize="16sp"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_button_unselected"
                android:padding="2dp">

                <TextView
                    android:id="@+id/btn_mode_sport"
                    android:layout_width="0dp"
                    android:layout_height="45dp"
                    android:layout_weight="1"
                    android:text="Thể thao"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground" />

                <TextView
                    android:id="@+id/btn_mode_eco"
                    android:layout_width="0dp"
                    android:layout_height="45dp"
                    android:layout_weight="1"
                    android:text="Tiết kiệm"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground" />
            </LinearLayout>

            <!-- Chế độ phục hồi -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chế độ phục hồi"
                android:textColor="#AAAAAA"
                android:textSize="16sp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_button_unselected"
                android:padding="2dp">

                <TextView
                    android:id="@+id/btn_regen_off"
                    android:layout_width="0dp"
                    android:layout_height="45dp"
                    android:layout_weight="1"
                    android:text="Tắt"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground" />

                <TextView
                    android:id="@+id/btn_regen_low"
                    android:layout_width="0dp"
                    android:layout_height="45dp"
                    android:layout_weight="1"
                    android:text="Thấp"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground" />

                <TextView
                    android:id="@+id/btn_regen_high"
                    android:layout_width="0dp"
                    android:layout_height="45dp"
                    android:layout_weight="1"
                    android:text="Cao"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- GIAO DIỆN SẠC XE (ẨN MẶC ĐỊNH) -->
    <LinearLayout
        android:id="@+id/layout_charging_dashboard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0A0F1A"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="20dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@android:drawable/ic_lock_idle_charging"
            android:tint="#00E5FF" />

        <TextView
            android:id="@+id/tv_charge_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đang sạc..."
            android:textColor="#00E5FF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"/>

        <ProgressBar
            android:id="@+id/pb_charge_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="15dp"
            android:layout_marginTop="30dp"
            android:progress="87"
            android:max="100" />

        <TextView
            android:id="@+id/tv_charge_soc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="87%"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginTop="10dp"/>

        <TextView
            android:id="@+id/tv_charge_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thời gian còn lại: 1h 20min"
            android:textColor="#AAAAAA"
            android:textSize="16sp"
            android:layout_marginTop="10dp"/>

        <TextView
            android:id="@+id/btn_stop_charging"
            android:layout_width="200dp"
            android:layout_height="50dp"
            android:layout_marginTop="40dp"
            android:background="@drawable/bg_button_unselected"
            android:text="DỪNG SẠC"
            android:gravity="center"
            android:textColor="#FF5252"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

</FrameLayout>